{
  "name": "tradeneu",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "npm run dev",
    "dev": "node scripts/devWithHistoricApi.mjs",
    "predev": "node scripts/syncTvChartLibrary.mjs",
    "dev:vite": "node scripts/viteOnlyWarn.mjs && vite",
    "dev:full": "node scripts/devWithHistoricApi.mjs",
    "tv:sync": "node scripts/syncTvChartLibrary.mjs",
    "prebuild": "node scripts/syncTvChartLibrary.mjs",
    "postinstall": "git submodule update --init --recursive && node scripts/syncTvChartLibrary.mjs",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "deploy:vercel": "vercel --prod",
    "import:xau": "node scripts/import-xau-csv.mjs",
    "server:historic": "node server/historicGoldApi.mjs",
    "market:sync": "node scripts/syncMarketLocal.mjs",
    "market:sync:bars": "node scripts/syncMarketLocal.mjs --bars-only",
    "market:sync:ticks": "node scripts/syncMarketLocal.mjs --ticks-only",
    "market:sync:ticks:missing": "node scripts/syncMarketLocal.mjs --ticks-only --missing-only",
    "market:sync:10s": "node scripts/syncMarketLocal.mjs --second-bars-only --second-step=10",
    "market:sync:10s:missing": "node scripts/syncMarketLocal.mjs --second-bars-only --second-step=10 --missing-only",
    "market:sync:1s": "node scripts/syncMarketLocal.mjs --second-bars-only --second-step=1",
    "market:sync:1s:missing": "node scripts/syncMarketLocal.mjs --second-bars-only --second-step=1 --missing-only",
    "market:sync:seconds": "node scripts/syncMarketLocal.mjs --second-bars-only",
    "market:sync:seconds:missing": "node scripts/syncMarketLocal.mjs --second-bars-only --missing-only",
    "market:sync:bars:missing": "node scripts/syncMarketLocal.mjs --bars-only --missing-only",
    "ml:venv": "node scripts/mlRunner.mjs venv",
    "ml:install": "node scripts/mlRunner.mjs install",
    "ml:api": "node scripts/mlRunner.mjs api",
    "ml:train": "node scripts/mlRunner.mjs train"
  },
  "devDependencies": {
    "autoprefixer": "^10.5.0",
    "daisyui": "^4.12.24",
    "postcss": "^8.5.12",
    "tailwindcss": "^3.4.17",
    "typescript": "~6.0.2",
    "vercel": "^54.21.1",
    "vite": "^8.0.10"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^6.6.0",
    "@vercel/blob": "^2.6.1",
    "better-sqlite3": "^12.11.1",
    "dukascopy-node": "^1.46.4",
    "express": "^5.1.0",
    "lightweight-charts": "^5.2.0",
    "multer": "^2.0.2"
  }
}
