# Copy to `.env.local` at repo root (gitignored). Loaded by `server/historicGoldApi.mjs`.

# Signs HTTP-only session cookies (min 16 characters). Required on Vercel production.
AUTH_SESSION_SECRET=change-me-to-a-long-random-string

# Dev: Vite port. Production (Vercel): https://tradeneu.com — no trailing slash.
AUTH_BASE_URL=http://localhost:5199
# AUTH_BASE_URL=https://tradeneu.com

# Local dev: accounts are saved to server-data/users.json automatically.
# Vercel production: link a Blob store (Dashboard → Storage → Blob → Connect to project).
# Optional for local testing against the same blob as production:
# BLOB_READ_WRITE_TOKEN=

# Market data (optional)
# TWELVE_DATA_API_KEY=
