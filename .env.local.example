# Copy to `.env.local` at repo root (gitignored). Loaded by `server/historicGoldApi.mjs`.

# Signs HTTP-only session cookies (min 16 characters). Required on Vercel production.
AUTH_SESSION_SECRET=change-me-to-a-long-random-string

# Dev: Vite port. Production (Vercel): https://tradeneu.com — no trailing slash.
AUTH_BASE_URL=http://localhost:5199
# AUTH_BASE_URL=https://tradeneu.com

# Local dev: accounts are saved to server-data/users.json automatically.
# Vercel production: link a Blob store (Dashboard → Storage → Blob → Connect to project).
# Optional for local testing against the same blob as production:
# BLOB_READ_WRITE_TOKEN=

# Market data (optional)
# TWELVE_DATA_API_KEY=
# Default provider chain: local SQLite first (10s bars), then Dukascopy, Twelve Data fallback
# MARKET_BAR_CHAIN=local,dukascopy,twelvedata
# VITE_MARKET_BAR_CHAIN=local,dukascopy,twelvedata
# DUKASCOPY_USE_CACHE=1
# DUKASCOPY_CACHE_PATH=server-data/dukascopy-cache
# DUKASCOPY_BATCH_SIZE=8
# DUKASCOPY_BATCH_PAUSE_MS=600

# Dukascopy tick API (Sprint 2 — GET /api/market/ticks)
# DUKASCOPY_TICK_PAGE_SIZE=50000
# DUKASCOPY_MAX_TICK_RANGE_SEC=21600
# MARKET_TICKS_CACHE_TTL_MS=300000
# MARKET_TICKS_CACHE_HISTORICAL_TTL_MS=900000
# Client tick cache (Sprint 3 — marketTickClient.ts)
# VITE_MARKET_TICKS_CACHE_TTL_MS=300000
# VITE_MARKET_TICKS_CACHE_HISTORICAL_TTL_MS=900000
# VITE_DUKASCOPY_MAX_TICK_RANGE_SEC=21600
# VITE_DUKASCOPY_TICK_PAGE_SIZE=50000
# VITE_CHART_MAX_TICKS=120000
# Persist full-session tick replay on 1t (localStorage: suplexity-chart-full-session-ticks)

# Local SQLite market store (Phase 1 — npm run market:sync)
# MARKET_DB_PATH=server-data/market.db
# MARKET_LOCAL_FIRST=1
# MARKET_FALLBACK_DUKASCOPY=1
# MARKET_SYNC_SYMBOLS=XAUUSD
# MARKET_TICK_RETENTION_DAYS=14
# MARKET_BARS_S1_RETENTION_DAYS=14
# MARKET_BARS_S5_RETENTION_DAYS=14
# MARKET_BARS_S10_RETENTION_DAYS=14
# MARKET_BARS_S15_RETENTION_DAYS=14
# MARKET_BARS_S20_RETENTION_DAYS=14
# MARKET_BARS_S30_RETENTION_DAYS=14
# MARKET_BARS_1M_RETENTION_DAYS=90
# MARKET_BARS_H1_RETENTION_DAYS=730
# MARKET_BARS_D1_RETENTION_DAYS=1825
# MARKET_BARS_MN1_RETENTION_DAYS=3650
# MARKET_SYNC_USE_CLI=1
# MARKET_SYNC_MIN_TICKS_PER_CHUNK=1000
# MARKET_SYNC_MIN_BARS_M1_PER_CHUNK=500
# MARKET_SYNC_API_RETRIES=3
# MARKET_SYNC_TICK_CHUNK_SEC=3600

# TradingView Advanced Charts (git submodule → npm run tv:sync)
# VITE_USE_TV_CHART=1
